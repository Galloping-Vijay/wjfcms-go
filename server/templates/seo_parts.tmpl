  {{ if config .Configs "baidu_union_verify" "" }}<meta name="baidu_union_verify" content="{{ config .Configs "baidu_union_verify" "" }}">{{ else }}<meta name="baidu_union_verify" content="285b65cf325abe072bde0437c133e008">{{ end }}
