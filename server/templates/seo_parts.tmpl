  <script>
    window.WJFCMSGOAuth={
      token:function(){return localStorage.getItem('home_token')||'';},
      user:function(){try{return JSON.parse(localStorage.getItem('home_user')||'null')||null;}catch(e){return null;}},
      clear:function(){localStorage.removeItem('home_token');localStorage.removeItem('home_user');this.renderAuthState();},
      formJSON:function(form){var data={};new FormData(form).forEach(function(v,k){data[k]=String(v).trim();});return data;},
      request:function(method,url,data){var headers={'Content-Type':'application/json'};if(this.token())headers.Authorization='Bearer '+this.token();return fetch(url,{method:method,headers:headers,body:data?JSON.stringify(data):undefined}).then(function(res){return res.json().then(function(body){if(!res.ok||body.code!==0)throw new Error(body.msg||'请求失败');return body;});});},
      get:function(url){return this.request('GET',url);},
      post:function(url,data){return this.request('POST',url,data);},
      put:function(url,data){return this.request('PUT',url,data);},
      loadCaptcha:function(form){return this.get('/api/auth/captcha').then(function(body){form.captcha_key.value=body.data.key;form.captcha_code.value='';var img=form.querySelector('[data-captcha-image]');if(img)img.src=body.data.image;});},
      renderAuthState:function(){var boxes=document.querySelectorAll('[data-home-auth-state]'),user=this.user(),token=this.token();boxes.forEach(function(box){if(token&&user){var name=user.name||user.email||'用户',avatar=user.avatar||'/images/config/avatar.jpg';box.innerHTML='<a class="home-user-chip" href="/user"><img src="'+escapeAttr(avatar)+'" alt=""><span>'+escapeHTML(name)+'</span></a><button type="button" data-home-logout>退出</button>';}else{box.innerHTML='<a class="primary" href="/login">登录</a><a href="/register">注册</a>';}});}
    };
    function escapeHTML(value){return String(value||'').replace(/[&<>"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];});}
    function escapeAttr(value){return escapeHTML(value).replace(/`/g,'&#96;');}
    window.WJFCMSAuth=window.WJFCMSGOAuth;
    document.addEventListener('click',function(event){var btn=event.target.closest('[data-refresh-captcha]');if(btn){var form=btn.closest('form');if(form)window.WJFCMSGOAuth.loadCaptcha(form);}});
    document.addEventListener('click',function(event){if(event.target.closest('[data-home-logout]')){window.WJFCMSGOAuth.clear();if(location.pathname==='/user')location.href='/';}});
    document.addEventListener('DOMContentLoaded',function(){window.WJFCMSGOAuth.renderAuthState();});
  </script>
</head>
<body>
<header class="top">
  <div class="top-inner">
    <a class="brand" href="/"><img src="{{ config .Configs "site_logo" "/images/config/avatar.jpg" }}" alt="{{ .SiteName }}"><span>{{ .SiteName }}</span></a>
    <nav class="nav">
      <a href="/" class="{{ if eq .CurrentPath "/" }}active{{ end }}">首页</a>
      {{ $activeCategoryID := .ActiveCategoryID }}{{ range .Categories }}<a href="/category/{{ .ID }}" class="{{ if eq .ID $activeCategoryID }}active{{ end }}">{{ .Name }}</a>{{ end }}
      {{ $currentPath := .CurrentPath }}{{ range .Navs }}<a href="{{ .URL }}" target="{{ if .Target }}{{ .Target }}{{ else }}_self{{ end }}" class="{{ if eq .URL $currentPath }}active{{ end }}">{{ .Name }}</a>{{ end }}
    </nav>
    <div class="home-auth-status" data-home-auth-state><a class="primary" href="/login">登录</a><a href="/register">注册</a></div>
  </div>
</header>
<main class="wrap">
  <div>
{{- end }}

{{ define "seo_layout_end" -}}
  </div>
  <aside>
    <section class="side"><h3>关于本站</h3><p>{{ if config .Configs "site_description" "" }}{{ config .Configs "site_description" "" }}{{ else }}{{ .SiteName }}{{ end }}</p></section>
    <section class="side"><h3>搜索</h3><form action="/search" method="get"><input name="q" placeholder="搜索文章" style="width:100%;height:38px;border:1px solid #d1d5db;border-radius:8px;padding:0 10px"></form></section>
    <section class="side"><h3>标签云</h3><div class="chips">{{ range .Tags }}<a href="/tag/{{ .ID }}">{{ .Name }}</a>{{ end }}</div></section>
    <section class="side side-media">
      <h3>{{ config .Configs "site_wechat_public_title" "公众号" }}</h3>
      <img src="{{ config .Configs "site_wechat_public" "/images/config/wx_public.jpg" }}" alt="公众号">
      {{ if config .Configs "site_wechat_public_desc" "" }}<p>{{ config .Configs "site_wechat_public_desc" "" }}</p>{{ end }}
    </section>
    {{ if config .Configs "site_sidebar_ad_html" "" }}
      <section class="side side-ad"><h3>{{ config .Configs "site_sidebar_ad_title" "推荐" }}</h3>{{ safeHTML (config .Configs "site_sidebar_ad_html" "") }}</section>
    {{ else if config .Configs "site_sidebar_ad_image" "" }}
      <section class="side side-ad"><h3>{{ config .Configs "site_sidebar_ad_title" "推荐" }}</h3>{{ if config .Configs "site_sidebar_ad_url" "" }}<a href="{{ config .Configs "site_sidebar_ad_url" "" }}" target="_blank" rel="noreferrer">{{ end }}<img src="{{ config .Configs "site_sidebar_ad_image" "" }}" alt="{{ config .Configs "site_sidebar_ad_title" "推荐" }}">{{ if config .Configs "site_sidebar_ad_url" "" }}</a>{{ end }}</section>
    {{ end }}
    <section class="side"><h3>热度榜</h3><ul>{{ range .HotArticles }}<li><a href="/article/{{ .ID }}">{{ .Title }}</a></li>{{ end }}</ul></section>
    <section class="side"><h3>友情链接</h3><div class="chips">{{ range .FriendLinks }}<a href="{{ .URL }}" target="_blank" rel="noreferrer">{{ .Name }}</a>{{ end }}</div></section>
    <section class="side side-link-form">
      <h3>申请友链</h3>
      <form id="friend-link-form">
        <input name="name" placeholder="网站名称" required>
        <input name="url" placeholder="https://example.com" required>
        <input name="email" type="email" placeholder="联系邮箱" required>
        <button type="submit">提交申请</button>
        <p class="side-message" id="friend-link-message"></p>
      </form>
    </section>
  </aside>
</main>
<div class="toolbar-mini" aria-label="快捷工具">
  <a href="/user" title="用户中心">人</a>
  <button type="button" data-toolbar="wechat" title="微信">微</button>
  <button type="button" data-toolbar="reward" title="打赏">赏</button>
  <button type="button" data-top title="返回顶部">顶</button>
</div>
<div class="toolbar-pop" id="toolbar-pop" hidden></div>
<footer class="footer">
  <p>Copyright © 2019-{{ .Year }} <a href="/">{{ .SiteName }}</a> All rights reserved</p>
  {{ if config .Configs "site_icp" "" }}<p><a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow noreferrer">{{ config .Configs "site_icp" "" }}</a></p>{{ end }}
  {{ if config .Configs "site_email" "" }}<p>举报邮箱：<a href="mailto:{{ config .Configs "site_email" "" }}">{{ config .Configs "site_email" "" }}</a></p>{{ end }}
</footer>
<div class="image-viewer" id="image-viewer" hidden aria-modal="true" role="dialog">
  <div class="image-viewer-head">
    <div class="image-viewer-title" id="image-viewer-title"></div>
    <button type="button" class="image-viewer-close" data-viewer-close aria-label="关闭">×</button>
  </div>
  <div class="image-viewer-stage">
    <button type="button" class="image-viewer-prev" data-viewer-prev aria-label="上一张">‹</button>
    <img class="image-viewer-img" id="image-viewer-img" alt="">
    <button type="button" class="image-viewer-next" data-viewer-next aria-label="下一张">›</button>
  </div>
  <div class="image-viewer-foot">
    <span class="image-viewer-count" id="image-viewer-count"></span>
    <a class="image-viewer-download" id="image-viewer-download" href="#" target="_blank" rel="noreferrer">查看原图</a>
  </div>
</div>
<script>
(function(){
  function esc(v){return String(v||'').replace(/[&<>"']/g,function(c){return({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];});}
  var friendForm=document.getElementById('friend-link-form');
  if(friendForm){
    friendForm.addEventListener('submit',function(e){
      e.preventDefault();
      var msg=document.getElementById('friend-link-message');
      msg.textContent='';
      window.WJFCMSGOAuth.post('/api/home/friend-links',window.WJFCMSGOAuth.formJSON(friendForm)).then(function(body){
        msg.textContent=body.msg||'申请已提交，请等待审核';
        friendForm.reset();
      }).catch(function(err){msg.textContent=err.message;});
    });
  }
  var pop=document.getElementById('toolbar-pop');
  document.addEventListener('click',function(e){
    var top=e.target.closest('[data-top]');
    if(top){window.scrollTo({top:0,behavior:'smooth'});return;}
    var btn=e.target.closest('[data-toolbar]');
    if(!btn){if(pop&&!e.target.closest('#toolbar-pop'))pop.hidden=true;return;}
    var type=btn.dataset.toolbar;
    if(type==='wechat'){
      pop.innerHTML='<strong>微信</strong><img src="/images/config/wx.jpg" alt="微信"><p>扫码联系站长</p>';
    }else{
      pop.innerHTML='<strong>打赏支持</strong><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px"><img src="/images/config/weixin_pay.jpg" alt="微信打赏"><img src="/images/config/ali_pay.jpg" alt="支付宝打赏"></div><p>感谢支持本站</p>';
    }
    pop.hidden=false;
  });
  document.querySelectorAll('.content pre').forEach(function(pre){
    if(pre.querySelector('.code-copy'))return;
    var btn=document.createElement('button');
    btn.type='button';
    btn.className='code-copy';
    btn.textContent='复制';
    pre.appendChild(btn);
    btn.addEventListener('click',function(){
      var clone=pre.cloneNode(true);
      var copyButton=clone.querySelector('.code-copy');
      if(copyButton)copyButton.remove();
      var code=clone.querySelector('code');
      var text=(code||clone).innerText.trim();
      function done(){btn.textContent='已复制';btn.classList.add('copied');setTimeout(function(){btn.textContent='复制';btn.classList.remove('copied');},1600);}
      if(navigator.clipboard&&navigator.clipboard.writeText){
        navigator.clipboard.writeText(text).then(done).catch(function(){});
      }else{
        var ta=document.createElement('textarea');ta.value=text;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);done();
      }
    });
  });
  var viewer=document.getElementById('image-viewer');
  var viewerImg=document.getElementById('image-viewer-img');
  var viewerTitle=document.getElementById('image-viewer-title');
  var viewerCount=document.getElementById('image-viewer-count');
  var viewerDownload=document.getElementById('image-viewer-download');
  var viewerImages=[];
  var viewerIndex=0;
  function refreshViewerImages(){
    viewerImages=Array.prototype.slice.call(document.querySelectorAll('.content img,.comment-main img')).filter(function(img){
      return img.currentSrc||img.src;
    });
  }
  function showViewer(index){
    refreshViewerImages();
    if(!viewerImages.length)return;
    viewerIndex=(index+viewerImages.length)%viewerImages.length;
    var img=viewerImages[viewerIndex];
    var src=img.currentSrc||img.src;
    var title=img.getAttribute('alt')||img.getAttribute('title')||'图片预览';
    viewerImg.src=src;
    viewerImg.alt=title;
    viewerTitle.textContent=title;
    viewerCount.textContent=(viewerIndex+1)+' / '+viewerImages.length;
    viewerDownload.href=src;
    viewer.hidden=false;
    document.body.style.overflow='hidden';
  }
  function closeViewer(){
    if(!viewer||viewer.hidden)return;
    viewer.hidden=true;
    viewerImg.removeAttribute('src');
    document.body.style.overflow='';
  }
  function stepViewer(offset){
    if(viewer.hidden)return;
    showViewer(viewerIndex+offset);
  }
  document.addEventListener('click',function(e){
    var img=e.target.closest('.content img,.comment-main img');
    if(img){
      e.preventDefault();
      refreshViewerImages();
      showViewer(Math.max(0,viewerImages.indexOf(img)));
      return;
    }
    if(e.target.closest('[data-viewer-close]')||e.target===viewer){closeViewer();return;}
    if(e.target.closest('[data-viewer-prev]')){stepViewer(-1);return;}
    if(e.target.closest('[data-viewer-next]')){stepViewer(1);}
  });
  document.addEventListener('keydown',function(e){
    if(!viewer||viewer.hidden)return;
    if(e.key==='Escape')closeViewer();
    if(e.key==='ArrowLeft')stepViewer(-1);
    if(e.key==='ArrowRight')stepViewer(1);
  });
})();
</script>
</body>
</html>
{{- end }}

{{ define "seo_article_list" -}}
<section class="list">
  {{ range .Articles }}
    <article class="card {{ if .IsTop }}is-top{{ end }}">
      <a href="/article/{{ .ID }}"><img src="{{ .Cover }}" alt="{{ .Title }}"></a>
      <div>
        <div class="card-title-row">{{ if .IsTop }}<span class="pin-badge">置顶</span>{{ end }}<h2><a href="/article/{{ .ID }}">{{ .TitleHTML }}</a></h2></div>
        <p>{{ .DescriptionHTML }}</p>
        <div class="meta"><span>{{ .Author }}</span><span>{{ .CreatedAt.Format "2006-01-02 15:04" }}</span><span>浏览 {{ .Click }}</span><a href="/article/{{ .ID }}">阅读原文</a></div>
      </div>
    </article>
  {{ else }}
    <div class="empty">暂无文章</div>
  {{ end }}
</section>
{{ if or .HasPrev .HasNext }}
  <nav class="pager">
    {{ if .HasPrev }}<a href="{{ .PrevURL }}">上一页</a>{{ end }}
    {{ range .Pages }}{{ if .Active }}<span class="active">{{ .Number }}</span>{{ else }}<a href="{{ .URL }}">{{ .Number }}</a>{{ end }}{{ end }}
    {{ if .HasNext }}<a href="{{ .NextURL }}">下一页</a>{{ end }}
  </nav>
{{ end }}
{{- end }}

