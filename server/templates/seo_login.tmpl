{{ template "seo_layout_start" . }}
<section class="auth-card">
  <h1>欢迎登录</h1>
  <form id="login-form" class="auth-form">
    <label>邮箱 / 昵称 / 手机号<input name="account" autocomplete="username" required></label>
    <label>密码<input name="password" type="password" autocomplete="current-password" required></label>
    {{ template "captcha_field" . }}
    <button type="submit">开始登录</button>
    <p class="form-message" id="form-message"></p>
  </form>
  <div class="oauth-links" aria-label="第三方登录">
    <a href="/api/home/auth/github">GitHub 登录</a>
    <a href="/api/home/auth/qq">QQ 登录</a>
    <a href="/api/home/auth/weibo">微博登录</a>
  </div>
  <div class="auth-links"><a href="/register">注册账号</a><a href="/forgot-password">忘记密码</a></div>
</section>
<script>
(function(){
  var form=document.getElementById('login-form'),msg=document.getElementById('form-message');
  var redirect=new URLSearchParams(location.search).get('redirect')||'/user';
  window.WJFCMGOAuth.loadCaptcha(form);
  form.addEventListener('submit',function(e){
    e.preventDefault();msg.textContent='';
    window.WJFCMGOAuth.post('/api/home/auth/login',window.WJFCMGOAuth.formJSON(form)).then(function(body){
      localStorage.setItem('home_token',body.data.token);
      localStorage.setItem('home_user',JSON.stringify(body.data.user));
      location.href=redirect;
    }).catch(function(err){msg.textContent=err.message;window.WJFCMGOAuth.loadCaptcha(form);});
  });
})();
</script>
{{ template "seo_layout_end" . }}
