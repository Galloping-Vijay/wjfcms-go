{{ template "seo_layout_start" . }}
<section class="auth-card">
  <h1>注册账号</h1>
  <form id="register-form" class="auth-form">
    <label>昵称<input name="name" autocomplete="name" required></label>
    <label>邮箱<input name="email" type="email" autocomplete="email" required></label>
    <label>邮箱验证码<span class="inline-code"><input name="code" inputmode="numeric" autocomplete="one-time-code" required><button type="button" id="send-code">发送验证码</button></span></label>
    <label>密码<input name="password" type="password" autocomplete="new-password" required></label>
    <label>确认密码<input name="password_confirm" type="password" autocomplete="new-password" required></label>
    {{ template "captcha_field" . }}
    <button type="submit">开始注册</button>
    <p class="form-message" id="form-message"></p>
  </form>
  <div class="oauth-links" aria-label="第三方注册登录">
    <a href="/api/auth/github">GitHub 登录</a>
    <a href="/api/auth/qq">QQ 登录</a>
    <a href="/api/auth/weibo">微博登录</a>
  </div>
  <div class="auth-links"><a href="/login">已有账号，去登录</a></div>
</section>
<script>
(function(){
  var form=document.getElementById('register-form'),msg=document.getElementById('form-message'),send=document.getElementById('send-code'),seconds=0,timer=null;
  window.WJFCMGOAuth.loadCaptcha(form);
  function tick(){seconds-=1;send.textContent=seconds>0?seconds+'s':'发送验证码';send.disabled=seconds>0;if(seconds<=0&&timer)clearInterval(timer);}
  send.addEventListener('click',function(){
    var email=form.email.value.trim();if(!email){msg.textContent='请先填写邮箱';return;}
    msg.textContent='';
    window.WJFCMGOAuth.post('/api/auth/email-code',{email:email,purpose:'register'}).then(function(body){
      msg.textContent=body.data&&body.data.debug_code?'开发验证码：'+body.data.debug_code:'验证码已发送，请查看邮箱';
      seconds=60;send.disabled=true;send.textContent='60s';timer=setInterval(tick,1000);
    }).catch(function(err){msg.textContent=err.message;});
  });
  form.addEventListener('submit',function(e){
    e.preventDefault();msg.textContent='';
    var data=window.WJFCMGOAuth.formJSON(form);
    if(data.password!==data.password_confirm){msg.textContent='两次输入的密码不一致';return;}
    delete data.password_confirm;
    window.WJFCMGOAuth.post('/api/auth/register',data).then(function(body){
      localStorage.setItem('home_token',body.data.token);
      localStorage.setItem('home_user',JSON.stringify(body.data.user));
      location.href='/user';
    }).catch(function(err){msg.textContent=err.message;window.WJFCMGOAuth.loadCaptcha(form);});
  });
})();
</script>
{{ template "seo_layout_end" . }}
