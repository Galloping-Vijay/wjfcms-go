{{ template "seo_layout_start" . }}
<section class="auth-card">
  <h1>找回密码</h1>
  <form id="forgot-form" class="auth-form">
    <label>注册邮箱<input name="email" type="email" autocomplete="email" required></label>
    <label>邮箱验证码<span class="inline-code"><input name="code" inputmode="numeric" autocomplete="one-time-code" required><button type="button" id="send-code">发送验证码</button></span></label>
    <label>新密码<input name="password" type="password" autocomplete="new-password" required></label>
    {{ template "captcha_field" . }}
    <button type="submit">重置密码</button>
    <p class="form-message" id="form-message"></p>
  </form>
  <div class="auth-links"><a href="/login">返回登录</a><a href="/register">注册账号</a></div>
</section>
<script>
(function(){
  var form=document.getElementById('forgot-form'),msg=document.getElementById('form-message'),send=document.getElementById('send-code'),seconds=0,timer=null;
  window.WJFCMGOAuth.loadCaptcha(form);
  function tick(){seconds-=1;send.textContent=seconds>0?seconds+'s':'发送验证码';send.disabled=seconds>0;if(seconds<=0&&timer)clearInterval(timer);}
  send.addEventListener('click',function(){
    var email=form.email.value.trim();if(!email){msg.textContent='请先填写邮箱';return;}
    window.WJFCMGOAuth.post('/api/home/auth/email-code',{email:email,purpose:'reset_password'}).then(function(body){
      msg.textContent=body.data&&body.data.debug_code?'开发验证码：'+body.data.debug_code:'验证码已发送，请查看邮箱';
      seconds=60;send.disabled=true;send.textContent='60s';timer=setInterval(tick,1000);
    }).catch(function(err){msg.textContent=err.message;});
  });
  form.addEventListener('submit',function(e){
    e.preventDefault();msg.textContent='';
    window.WJFCMGOAuth.post('/api/home/auth/reset-password',window.WJFCMGOAuth.formJSON(form)).then(function(body){
      msg.textContent=body.msg||'密码已重置，请重新登录';
      setTimeout(function(){location.href='/login';},900);
    }).catch(function(err){msg.textContent=err.message;window.WJFCMGOAuth.loadCaptcha(form);});
  });
})();
</script>
{{ template "seo_layout_end" . }}
