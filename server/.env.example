# =========================
# 应用基础配置
# =========================
# 应用名称，会用于安装向导、日志和部分页面默认站点名。
APP_NAME=wjfcm-go
# 运行环境。local/development 表示开发环境，production/prod 表示生产环境。
# 未显式设置 APP_DEBUG 时，production/prod 会默认关闭 debug。
APP_ENV=local
# 应用密钥。安装向导会自动生成；JWT_SECRET 未配置或仍为 change-me 时，会作为 JWT 签名密钥兜底。
APP_KEY=
# 调试模式。true 时 Gin 使用 debug 模式，并允许部分接口返回调试信息。
APP_DEBUG=true
# Gin 服务监听端口。
APP_PORT=8080
# 站点访问地址，用于生成文章原文链接、sitemap、OAuth 回调等绝对地址。
APP_URL=http://localhost:8080
# 是否开启 Gin 控制台彩色日志。
APP_CONSOLE_COLOR=true

# =========================
# 日志配置
# =========================
# 日志输出通道。支持 stack/stdout/console、stderr、single/file、daily、null/discard/none。
LOG_CHANNEL=stack
# 服务运行日志保存目录。仅 LOG_CHANNEL=single/file/daily 时使用。
LOG_PATH=storage/logs
# 服务运行日志单文件最大大小，单位 MB；超过后自动按时间分割。
LOG_MAX_SIZE_MB=50
# 是否开启请求链路日志。开启后每个请求都会生成 request_id，并记录请求参数、响应和 SQL。
REQUEST_LOG_ENABLED=false
# 请求日志类型。当前支持 json。
REQUEST_LOG_TYPE=json
# 请求日志保存目录。日志会按日期目录写入 JSON Lines 文件，并支持按 request_id 查询。
REQUEST_LOG_PATH=storage/request-logs
# 请求日志输出方式：file/console/stdout/both。需要按 request_id 查询时建议使用 file 或 both。
REQUEST_LOG_OUTPUT=file
# 请求日志记录等级：debug/info/warn/error。info 记录所有请求，warn 只记录 4xx/5xx，error 只记录 5xx。
REQUEST_LOG_LEVEL=info
# 是否只记录 /api/ 开头的接口请求。默认只记录接口，不记录前台 HTML 页面。
REQUEST_LOG_ONLY_API=true
# 请求 body 最大记录大小，单位 KB；超过会截断，不影响接口正常读取完整 body。
REQUEST_LOG_MAX_BODY_KB=256
# 响应 body 最大记录大小，单位 KB；超过会截断。默认只保留接口返回结果的前 64KB。
REQUEST_LOG_MAX_RESPONSE_KB=64
# 请求链路日志单文件最大大小，单位 MB；超过后自动生成分片文件。
REQUEST_LOG_MAX_FILE_MB=20
# 请求日志保留天数，当前作为配置预留；后续可接入定时清理。
REQUEST_LOG_KEEP_DAYS=14

# =========================
# JWT 配置
# =========================
# JWT 签名密钥。生产环境必须改成足够长的随机字符串；为空或仍为 change-me 时会尝试使用 APP_KEY 兜底。
JWT_SECRET=change-me
# 后台和前台 Access Token 有效期，单位：分钟。
JWT_EXPIRES_MINUTES=120
# 后台 Refresh Token 有效期，单位：分钟。
JWT_REFRESH_EXPIRES_MINUTES=10080

# =========================
# 数据库配置
# =========================
# 数据库连接类型。当前项目固定使用 MySQL，此项主要保留兼容旧配置习惯。
DB_CONNECTION=mysql
# MySQL 地址。
DB_HOST=127.0.0.1
# MySQL 端口。
DB_PORT=3306
# MySQL 数据库名。安装向导会尝试自动创建。
DB_DATABASE=homestead
# MySQL 用户名。
DB_USERNAME=homestead
# MySQL 密码。
DB_PASSWORD=secret
# 数据表前缀。兼容旧项目默认 wjf_ 表。
DB_PREFIX=wjf_
# 是否打印所有 SQL。
DB_LOG_SQL=false
# 是否打印慢 SQL。
DB_LOG_SLOW_SQL=true
# 是否打印异常 SQL。
DB_LOG_ERROR_SQL=true
# GORM 日志级别：silent/error/warn/info。
DB_LOG_LEVEL=info
# 慢 SQL 阈值，单位：毫秒。
DB_SLOW_THRESHOLD_MS=200

# =========================
# 运行时驱动配置
# =========================
# 广播驱动。当前主要保留兼容旧 Laravel 配置，默认 log。
BROADCAST_DRIVER=log
# 缓存驱动。当前主要保留扩展入口，默认 file。
CACHE_DRIVER=file
# 队列驱动。当前主要保留扩展入口，默认 sync。
QUEUE_CONNECTION=sync
# Session 驱动。当前主要保留扩展入口，默认 file。
SESSION_DRIVER=file
# Session 有效期，单位：分钟。当前主要保留扩展入口。
SESSION_LIFETIME=120

# =========================
# Redis 配置
# =========================
# Redis 地址。当前主要保留给后续缓存/队列扩展使用。
REDIS_HOST=127.0.0.1
# Redis 密码。无密码可填 null 或留空。
REDIS_PASSWORD=null
# Redis 端口。
REDIS_PORT=6379

# =========================
# 邮件配置
# =========================
# 邮件驱动。当前支持 smtp；其他值会跳过真实发送。
MAIL_DRIVER=smtp
# SMTP 服务地址。
MAIL_HOST=smtp.mailtrap.io
# SMTP 端口，常见 465/587。
MAIL_PORT=465
# SMTP 用户名。
MAIL_USERNAME=null
# SMTP 密码。
MAIL_PASSWORD=null
# SMTP 加密方式：ssl/tls/null。
MAIL_ENCRYPTION=null
# 发件邮箱。为空时会尝试使用 MAIL_USERNAME。
MAIL_FROM_ADDRESS=
# 默认收件邮箱，用于部分通知类邮件。
MAIL_TO_ADDRESS=

# =========================
# AWS 配置
# =========================
# AWS Access Key。当前主要保留旧配置兼容和后续对象存储扩展。
AWS_ACCESS_KEY_ID=
# AWS Secret Key。
AWS_SECRET_ACCESS_KEY=
# AWS 默认区域。
AWS_DEFAULT_REGION=us-east-1
# AWS S3 Bucket。
AWS_BUCKET=

# =========================
# Pusher 配置
# =========================
# Pusher App ID。当前主要保留旧配置兼容和后续广播扩展。
PUSHER_APP_ID=
# Pusher App Key。
PUSHER_APP_KEY=
# Pusher App Secret。
PUSHER_APP_SECRET=
# Pusher 集群。
PUSHER_APP_CLUSTER=mt1
# 前端兼容变量，保留旧 Laravel Mix 风格。
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# 前端兼容变量，保留旧 Laravel Mix 风格。
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =========================
# 百家号配置
# =========================
# 百家号 App ID，用于文章发布和回调解密。
BAIJIAHAO_APP_ID=
# 百家号 App Token，用于文章发布。
BAIJIAHAO_APP_TOKEN=
# 百家号 You Token，用于 /baidu/serve 回调签名校验。
BAIJIAHAO_APP_YOU_TOKEN=
# 旧项目变量名，保留兼容。建议新环境使用 BAIJIAHAO_APP_ENCODING_AES_KEY。
BAIJIAHAO_APP_Encoding_AESKe=
# 百家号 Encoding AES Key，用于 /baidu/serve 回调解密。
BAIJIAHAO_APP_ENCODING_AES_KEY=

# =========================
# 图灵机器人配置
# =========================
# 图灵机器人 API Key，用于微信公众号消息兜底回复。
TULING_API_KEY=
# 图灵机器人 API 地址。
TULING_API_URL=

# =========================
# QQ AI 配置
# =========================
# QQ AI AppID，用于微信公众号消息兜底回复。
QQ_AI_APPID=
# QQ AI AppKey。
QQ_AI_APPKEY=
# QQ AI 接口地址。
QQ_AI_URL=

# =========================
# 微信公众号配置
# =========================
# 公众号 AppID。
WECHAT_OFFICIAL_ACCOUNT_APPID=
# 公众号 AppSecret。
WECHAT_OFFICIAL_ACCOUNT_SECRET=
# 公众号服务器 Token，用于 /wechat 服务器校验。
WECHAT_OFFICIAL_ACCOUNT_TOKEN=
# 公众号 EncodingAESKey。
WECHAT_OFFICIAL_ACCOUNT_AES_KEY=

# =========================
# 百度站长配置
# =========================
# 百度主动推送站点域名，通常为 https://www.example.com。
BAIDU_SITE_BASE=
# 百度主动推送 API 地址。
BAIDU_SITE_API=

# =========================
# 微信网页版授权配置
# =========================
# 微信网页授权 Client ID。当前保留配置入口，后续可接入前台微信登录。
WECHATWEB_CLIENT_ID=
# 微信网页授权 Client Secret。
WECHATWEB_CLIENT_SECRET=
# 微信网页授权回调地址。
WECHATWEB_REDIRECT_URI=

# =========================
# 前台第三方 OAuth 登录
# =========================
# GitHub OAuth Client ID。
GITHUB_CLIENT_ID=
# GitHub OAuth Client Secret。
GITHUB_CLIENT_SECRET=
# GitHub OAuth 回调地址，需与 GitHub 后台配置完全一致。
GITHUB_REDIRECT=http://localhost:8080/api/home/auth/github/callback
# QQ OAuth Client ID。
QQ_CLIENT_ID=
# QQ OAuth Client Secret。
QQ_CLIENT_SECRET=
# QQ OAuth 回调地址，需与 QQ 互联后台配置完全一致。
QQ_REDIRECT=http://localhost:8080/api/home/auth/qq/callback
# 微博 OAuth Client ID。
WEIBO_CLIENT_ID=
# 微博 OAuth Client Secret。
WEIBO_CLIENT_SECRET=
# 微博 OAuth 回调地址，需与微博开放平台配置完全一致。
WEIBO_REDIRECT=http://localhost:8080/api/home/auth/weibo/callback

# =========================
# 跨域配置
# =========================
# 允许访问 API 的前端源，多个用英文逗号分隔；单域名生产部署通常可以写成 https://www.example.com。
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://blog.localhost

# =========================
# 静态资源和上传配置
# =========================
# public 目录路径。无源码部署建议使用绝对路径，例如 /www/wwwroot/wjfcm-go/public。
PUBLIC_DIR=../public
# 上传文件保存到 PUBLIC_DIR 下的子目录。
UPLOAD_BASE_PATH=uploads
